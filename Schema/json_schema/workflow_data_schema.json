{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/workflow_schema.json",
  "title": "Workflow Schema",
  "type": "object",
  "required": ["workflow_id", "entry", "nodes"],
  "additionalProperties": false,
  "properties": {
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "entry": {
      "type": "integer",
      "description": "Entry node id"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/node" }
    }
    
  },
  "definitions": {
    "node": {
      "type": "object",
      "required": ["id", "type", "inputs", "outputs", "params"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer",
          "description": "Node id"
        },
        "type": {
          "type": "string",
          "description": "Node type id"
        },
        "listen": {
          "type": "array",
          "items": { "type": "integer" },
          "uniqueItems": true,
          "description": "Allowed incoming node ids"
        },
        "outputs": {
          "type": "array",
          "items": { "type": ["integer", "null"] },
          "uniqueItems": true,
          "description": "Outgoing node ids, null means end"
        },
        "context": {
          "type": "object",
          "additionalProperties": true,
          "description": "Context storage object attached to node"
        },
        "params": {
          "type": "object",
          "description": "Node parameters",
          "additionalProperties": true,
          "properties": {
            "context_slot": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "key"],
                "properties": {
                  "id": { "type": "integer" },
                  "key": { "type": "string" }
                }
              },
              "uniqueItems": true,
              "description": "List of {id:int, key:str} pairs to lookup context entries"
            },
            "config_options": {
              "type": "array",
              "items": {},
              "description": "Optional list of config options"
            }
          }
        }
      }
    }
  }
}
