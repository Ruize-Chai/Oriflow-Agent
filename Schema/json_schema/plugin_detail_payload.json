{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/plugin_detail_payload.json",
  "title": "Plugin Detail Payload",
  "type": "object",
  "required": ["plugin"],
  "properties": {
    "plugin": {
      "type": "object",
      "properties": {
        "id": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "category": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "type"],
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
