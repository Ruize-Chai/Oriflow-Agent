{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Node State List Payload",
  "type": "object",
  "required": ["workflow_id", "states"],
  "additionalProperties": false,
  "properties": {
    "workflow_id": { "type": "string" },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "state"],
        "properties": {
          "node_id": { "type": "integer" },
          "state": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
