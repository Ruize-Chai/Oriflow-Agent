{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://example.com/schemas/node_schema.json",
	"title": "Node Schema",
	"type": "object",
	"required": ["type", "inputs", "outputs", "params"],
	"additionalProperties": false,
	"properties": {
		"type": {
			"type": "string",
			"description": "Node type id"
		},
		"listen": {
			"type": "array",
			"items": { "type": "integer" },
			"uniqueItems": true,
			"description": "Allowed incoming node ids"
		},
		"outputs": {
			"type": "array",
			"items": { "type": ["integer", "null"] },
			"uniqueItems": true,
			"description": "Outgoing node ids, null means end"
		},
		"context": {
			"type": "object",
			"additionalProperties": true,
			"description": "Context storage object (arbitrary key/value pairs) attached to node"
		},
		"params": {
			"type": "object",
			"description": "Skill params with optional context placement",
			"additionalProperties": true,
			"properties": {
				"context_slot": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["id", "key"],
						"properties": {
							"id": { "type": "integer" },
							"key": { "type": "string" }
						}
					},
					"uniqueItems": true,
					"description": "List of {id:int, key:str} pairs to lookup context entries"
				},
				
				"config_options": {
					"type": "array",
					"items": {},
					"description": "Optional list of config options"
				}
			}
		}
	}
}